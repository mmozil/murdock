# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://murdock:murdock@localhost:5432/murdock

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/5

# ── LLM (env-based, padrão Tier Agent — zero hardcode) ──
# Provider primário (default MiniMax via endpoint OpenAI-compatible)
DEFAULT_LLM_PROVIDER=minimax
DEFAULT_LLM_MODEL=MiniMax-M2
DEFAULT_LLM_BASE_URL=https://api.minimax.io/v1
DEFAULT_LLM_API_KEY=

# Fallback (acionado se o primário falhar)
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Auth ──────────────────────────────────────
SECRET_KEY=change-me-in-production
API_KEY=murdock-api-key-change-me

# ── Server ────────────────────────────────────
ENVIRONMENT=development
PORT=8010
